# ============================================
# THEUSMARKT PIX BACKEND — VARIÁVEIS DE AMBIENTE
# ============================================
# Copie para .env e preencha com seus dados reais.
# NUNCA suba o .env para o GitHub.

# ── MERCADO PAGO ──
# Pegue em: mercadopago.com.br → Seu negócio → Credenciais → Produção
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL pública deste backend (usada para o Mercado Pago enviar o webhook)
# Exemplo: https://theusmarkt-pix.up.railway.app
BACKEND_URL=https://SEU-BACKEND-AQUI.up.railway.app

# URL do seu site (para CORS — libera chamadas apenas do seu domínio)
FRONTEND_URL=https://seusite.netlify.app

# Porta local para desenvolvimento
PORT=3000
